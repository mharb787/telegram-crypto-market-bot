[Unit]
Description=Telegram Crypto Market Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/telegram-crypto-market-bot
EnvironmentFile=/opt/telegram-crypto-market-bot/.env
ExecStart=/usr/bin/npm start
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
